# ============================================
# Social Data Vault — Environment Configuration
# ============================================

# App Settings
APP_NAME="Social Data Vault"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/socialdatavault
DATABASE_TEST_URL=postgresql://postgres:postgres@db:5432/socialdatavault_test

# Redis (Celery + Cache)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=socialdata

# AWS / Cloud Storage
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=socialdatavault-raw-data
S3_PROCESSED_BUCKET=socialdatavault-processed

# Social Media API Keys
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret

INSTAGRAM_ACCESS_TOKEN=your-instagram-token
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-token

REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=SocialDataVault/1.0

YOUTUBE_API_KEY=your-youtube-api-key

# Proxy Configuration
PROXY_API_KEY=your-brightdata-key
PROXY_POOL_SIZE=100
PROXY_ROTATION_INTERVAL=300

# Scraping Settings
MAX_CONCURRENT_SCRAPERS=50
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3
RATE_LIMIT_PER_MINUTE=60

# Monetization
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws
